#!/usr/bin/env bash
# dmenu wrapper with mememacs color scheme

# Colors from mememacs visual.el
COLOR_BG="black"
COLOR_FG="#faf7f7"           # hint-of-red
COLOR_SEL_FG="#F689FF"       # heliotrope
DMENU_WRAP_AROUND="true"

exec /usr/bin/dmenu \
    -l 20 \
    -fn "monospace:size=18" \
    -nb "$COLOR_BG" \
    -nf "$COLOR_FG" \
    -sb "$COLOR_BG" \
    -sf "$COLOR_SEL_FG" \
    "$@"
